{
	"name": "super-kingdoms",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n vite,tsc,env,convex -c blue,yellow,magenta,green \"vite\" \"npm run tsc\" \"node setupEnv.mjs\" \"npx convex dev --typecheck enable\"",
		"dev:server:init": "npx convex dev --configure new --dev-deployment local --once && npm run lint:fix",
		"dev:server:dashboard": "npx convex dashboard",
		"tsc": "tsc -b --watch",
		"build": "tsc -b && vite build",
		"lint": "biome check .",
		"lint:fix": "biome check --fix --unsafe .",
		"test": "vitest run",
		"preview": "vite preview",
		"amend": "npm run lint:fix && git add . && git commit --amend --no-edit"
	},
	"dependencies": {
		"@auth/core": "^0.37.0",
		"@convex-dev/auth": "^0.0.91",
		"@picocss/pico": "^2.1.1",
		"@tanstack/react-router": "^1.166.2",
		"convex": "^1.34.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.71.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tanstack/router-plugin": "^1.166.2",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"concurrently": "^9.2.1",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
